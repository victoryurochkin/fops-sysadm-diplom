```
server {
    listen 80;
    server_name victoryur.tech www.victoryur.tech;
    root /var/www/victoryur.tech/public;
    index index.html;
    access_log /var/log/nginx/victoryur.tech.access.log;
    error_log  /var/log/nginx/victoryur.tech.error.log;
    location / {
        try_files $uri $uri/ =404;
    }
    location = /health {
        access_log off;
        return 200 "OK\n";
    }
}
