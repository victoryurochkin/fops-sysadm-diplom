#!/bin/bash
set -e

# ============================================
# Скрипт генерации полной структуры проекта
# Ansible + Terraform + CI/CD для инфраструктуры victoryur.tech
# Автор: Юрочкин Виктор Алексеевич
# ============================================

echo "Создаём полную структуру проекта Ansible + Terraform + CI/CD"

# Корневые директории
ANSIBLE_DIR="ansible"
TERRAFORM_DIR="terraform"
GITHUB_DIR="$ANSIBLE_DIR/.github/workflows"

# Создание структуры каталогов
mkdir -p $ANSIBLE_DIR/{inventory,group_vars,host_vars,playbooks}
mkdir -p $ANSIBLE_DIR/roles/{common,waf,nginx,backend,zabbix-agent,zabbix-server,filebeat,elk}/{tasks,handlers,templates,defaults,vars,meta}
mkdir -p $GITHUB_DIR
mkdir -p $TERRAFORM_DIR

# ============================================
# 1. Инвентарный файл
cat > $ANSIBLE_DIR/inventory/production.yml <<'EOF'
all:
  children:
    waf:
      hosts:
        bunker:
          ansible_host: 192.168.1.10
    balancer:
      hosts:
        balancer:
          ansible_host: 192.168.1.90
    backend:
      hosts:
        web01:
          ansible_host: 192.168.1.88
        web02:
          ansible_host: 192.168.1.89
    zabbix_server:
      hosts:
        zabbix:
          ansible_host: 192.168.1.83
    elk:
      hosts:
        elk:
          ansible_host: 192.168.1.31
  vars:
    ansible_user: root
    ansible_ssh_private_key_file: ~/.ssh/id_rsa
EOF

# ============================================
# 2. Групповые переменные
cat > $ANSIBLE_DIR/group_vars/all.yml <<'EOF'
# Общие переменные
domain: victoryur.tech
zabbix_server_ip: 192.168.1.83
elasticsearch_host: 192.168.1.31
elasticsearch_port: 9200

# Пароли (заменить реальными и зашифровать vault)
zabbix_db_password: "secure_password"
elastic_password: "*B9=5+iuJwaD2Ivt8=fq"
kibana_system_password: "aSGYpvf6mtoQPT2MkMXa"
EOF

# ============================================
# 3. Основной плейбук site.yml
cat > $ANSIBLE_DIR/playbooks/site.yml <<'EOF'
- hosts: all
  become: yes
  roles:
    - common

- hosts: waf
  become: yes
  roles:
    - waf

- hosts: balancer
  become: yes
  roles:
    - nginx

- hosts: backend
  become: yes
  roles:
    - backend
    - filebeat
    - zabbix-agent

- hosts: zabbix_server
  become: yes
  roles:
    - zabbix-server

- hosts: elk
  become: yes
  roles:
    - elk
EOF

# ============================================
# 4. Роль common
cat > $ANSIBLE_DIR/roles/common/tasks/main.yml <<'EOF'
- name: install base packages
  apt:
    name:
      - curl
      - vim
      - git
      - htop
      - net-tools
      - wget
    update_cache: yes
EOF

# ============================================
# 5. Роль waf
cat > $ANSIBLE_DIR/roles/waf/tasks/main.yml <<'EOF'
- name: install docker
  apt:
    name:
      - docker.io
      - docker-compose
    state: present
    update_cache: yes

- name: start docker
  systemd:
    name: docker
    state: started
    enabled: yes

- name: create directory
  file:
    path: /opt/bunkerweb
    state: directory

- name: copy docker-compose.yml
  template:
    src: docker-compose.yml.j2
    dest: /opt/bunkerweb/docker-compose.yml

- name: start bunkerweb
  command: docker compose up -d
  args:
    chdir: /opt/bunkerweb
EOF

cat > $ANSIBLE_DIR/roles/waf/templates/docker-compose.yml.j2 <<'EOF'
version: '3'
services:
  bunkerweb:
    image: bunkerity/bunkerweb-all-in-one:1.6.7
    ports:
      - "80:8080"
      - "443:8443"
    restart: always
    environment:
      - SERVER_NAME={{ domain }}
      - USE_REVERSE_PROXY=yes
      - REVERSE_PROXY_HOST_1=http://192.168.1.90
EOF

# ============================================
# 6. Роль nginx (балансировщик)
cat > $ANSIBLE_DIR/roles/nginx/tasks/main.yml <<'EOF'
- name: install nginx
  apt:
    name: nginx
    state: present

- name: configure nginx
  template:
    src: nginx-balancer.conf.j2
    dest: /etc/nginx/sites-available/default

- name: restart nginx
  service:
    name: nginx
    state: restarted
EOF

cat > $ANSIBLE_DIR/roles/nginx/templates/nginx-balancer.conf.j2 <<'EOF'
upstream backend_cluster {
    least_conn;
    server 192.168.1.88:80 max_fails=2 fail_timeout=5s;
    server 192.168.1.89:80 max_fails=2 fail_timeout=5s;
    keepalive 32;
}

server {
    listen 80 default_server;
    server_name {{ domain }} www.{{ domain }};

    access_log /var/log/nginx/lb.access.log;
    error_log /var/log/nginx/lb.error.log warn;

    location = /health {
        access_log off;
        return 200 "OK\n";
    }

    location / {
        proxy_pass http://backend_cluster;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 3s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;
        proxy_next_upstream error timeout http_502 http_503 http_504;
        proxy_next_upstream_tries 2;
    }
}
EOF

# ============================================
# 7. Роль backend (веб-сервер)
cat > $ANSIBLE_DIR/roles/backend/tasks/main.yml <<'EOF'
- name: install nginx
  apt:
    name: nginx
    state: present

- name: copy nginx config
  template:
    src: nginx-backend.conf.j2
    dest: /etc/nginx/sites-available/default

- name: create web directory
  file:
    path: /var/www/html
    state: directory

- name: copy index.html
  template:
    src: index.html.j2
    dest: /var/www/html/index.html

- name: create .node file
  copy:
    content: "{{ inventory_hostname }}"
    dest: /var/www/html/.node

- name: restart nginx
  service:
    name: nginx
    state: restarted
EOF

cat > $ANSIBLE_DIR/roles/backend/templates/nginx-backend.conf.j2 <<'EOF'
server {
    listen 80;
    root /var/www/html;
    index index.html;
    server_name {{ domain }} www.{{ domain }};
    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;

    location / {
        try_files $uri $uri/ =404;
    }

    location = /health {
        access_log off;
        return 200 "OK\n";
    }
}
EOF

cat > $ANSIBLE_DIR/roles/backend/templates/index.html.j2 <<'EOF'
<!DOCTYPE html>
<html>
<head><title>{{ inventory_hostname }}</title></head>
<body><h1>{{ inventory_hostname }}</h1></body>
</html>
EOF

# ============================================
# 8. Роль zabbix-agent
cat > $ANSIBLE_DIR/roles/zabbix-agent/tasks/main.yml <<'EOF'
- name: add zabbix repository
  apt:
    deb: https://repo.zabbix.com/zabbix/6.0/ubuntu-arm64/pool/main/z/zabbix-release/zabbix-release_6.0-5+ubuntu22.04_all.deb

- name: install zabbix-agent
  apt:
    name: zabbix-agent
    state: present
    update_cache: yes

- name: configure agent
  template:
    src: zabbix_agentd.conf.j2
    dest: /etc/zabbix/zabbix_agentd.conf

- name: allow ufw port 10050
  ufw:
    rule: allow
    port: '10050'
    proto: tcp

- name: start and enable agent
  systemd:
    name: zabbix-agent
    state: started
    enabled: yes
EOF

cat > $ANSIBLE_DIR/roles/zabbix-agent/templates/zabbix_agentd.conf.j2 <<'EOF'
Server={{ zabbix_server_ip }}
ServerActive={{ zabbix_server_ip }}
Hostname={{ inventory_hostname }}
EOF

# ============================================
# 9. Роль zabbix-server
cat > $ANSIBLE_DIR/roles/zabbix-server/tasks/main.yml <<'EOF'
- name: install mariadb
  apt:
    name: mariadb-server
    state: present

- name: start mariadb
  systemd:
    name: mariadb
    state: started
    enabled: yes

- name: add zabbix repository
  apt:
    deb: https://repo.zabbix.com/zabbix/7.0/debian/pool/main/z/zabbix-release/zabbix-release_7.0-1+debian12_all.deb

- name: install zabbix server packages
  apt:
    name:
      - zabbix-server-mysql
      - zabbix-frontend-php
      - zabbix-nginx-conf
      - zabbix-sql-scripts
      - zabbix-agent2
    state: present
    update_cache: yes

- name: create database and user
  mysql_db:
    name: zabbix
    state: present
    encoding: utf8mb4
    collation: utf8mb4_bin

- name: create zabbix user
  mysql_user:
    name: zabbix
    password: "{{ zabbix_db_password }}"
    priv: 'zabbix.*:ALL'
    state: present
    host: localhost

- name: enable log_bin_trust_function_creators
  mysql_variables:
    variable: log_bin_trust_function_creators
    value: 1

- name: import database schema
  mysql_db:
    name: zabbix
    state: import
    target: /usr/share/zabbix-sql-scripts/mysql/server.sql.gz

- name: disable log_bin_trust_function_creators
  mysql_variables:
    variable: log_bin_trust_function_creators
    value: 0

- name: configure zabbix server
  template:
    src: zabbix_server.conf.j2
    dest: /etc/zabbix/zabbix_server.conf
  notify: restart zabbix-server

- name: configure nginx for zabbix
  template:
    src: nginx_zabbix.conf.j2
    dest: /etc/zabbix/nginx.conf
  notify: reload nginx

- name: start and enable services
  systemd:
    name: "{{ item }}"
    state: started
    enabled: yes
  loop:
    - zabbix-server
    - zabbix-agent2
    - nginx
    - php8.2-fpm
EOF

cat > $ANSIBLE_DIR/roles/zabbix-server/handlers/main.yml <<'EOF'
- name: restart zabbix-server
  systemd:
    name: zabbix-server
    state: restarted

- name: reload nginx
  systemd:
    name: nginx
    state: reloaded
EOF

cat > $ANSIBLE_DIR/roles/zabbix-server/templates/zabbix_server.conf.j2 <<'EOF'
DBHost=localhost
DBName=zabbix
DBUser=zabbix
DBPassword={{ zabbix_db_password }}
EOF

cat > $ANSIBLE_DIR/roles/zabbix-server/templates/nginx_zabbix.conf.j2 <<'EOF'
server {
    listen 80;
    server_name z.victoryur.tech;

    root /usr/share/zabbix;
    index index.php index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.2-fpm.sock;
    }
}
EOF

# ============================================
# 10. Роль filebeat (на бэкендах)
cat > $ANSIBLE_DIR/roles/filebeat/tasks/main.yml <<'EOF'
- name: add elastic repository
  apt_repository:
    repo: "deb [trusted=yes] https://mirror.yandex.ru/mirrors/elastic/7/ stable main"
    state: present

- name: install filebeat
  apt:
    name: filebeat
    state: present
    update_cache: yes

- name: copy certificate (если требуется)
  copy:
    src: http_ca.crt
    dest: /etc/filebeat/http_ca.crt
    mode: '0644'
  when: elasticsearch_ssl | default(False)

- name: configure filebeat
  template:
    src: filebeat.yml.j2
    dest: /etc/filebeat/filebeat.yml

- name: start and enable filebeat
  systemd:
    name: filebeat
    state: started
    enabled: yes
EOF

cat > $ANSIBLE_DIR/roles/filebeat/templates/filebeat.yml.j2 <<'EOF'
filebeat.inputs:
- type: log
  enabled: true
  paths:
    - /var/log/nginx/access.log
    - /var/log/nginx/error.log
  fields:
    service: nginx
    server: {{ inventory_hostname }}

output.elasticsearch:
  hosts: ["https://{{ elasticsearch_host }}:{{ elasticsearch_port }}"]
  username: "elastic"
  password: "{{ elastic_password }}"
  ssl.certificate_authorities: ["/etc/filebeat/http_ca.crt"]

setup.kibana:
  host: "{{ elasticsearch_host }}:5601"
EOF

# ============================================
# 11. Роль elk (elasticsearch + kibana)
cat > $ANSIBLE_DIR/roles/elk/tasks/main.yml <<'EOF'
- name: add elastic GPG key
  apt_key:
    url: https://artifacts.elastic.co/GPG-KEY-elasticsearch
    state: present

- name: add elastic repository
  apt_repository:
    repo: "deb [signed-by=/usr/share/keyrings/elastic.gpg] https://mirror.yandex.ru/mirrors/elastic/8/ stable main"
    state: present

- name: install elasticsearch
  apt:
    name: elasticsearch
    state: present

- name: set vm.max_map_count
  sysctl:
    name: vm.max_map_count
    value: '262144'
    state: present
    reload: yes

- name: configure elasticsearch
  template:
    src: elasticsearch.yml.j2
    dest: /etc/elasticsearch/elasticsearch.yml
  notify: restart elasticsearch

- name: start elasticsearch
  systemd:
    name: elasticsearch
    state: started
    enabled: yes

- name: install kibana
  apt:
    name: kibana
    state: present

- name: copy certificate
  copy:
    src: http_ca.crt
    dest: /etc/kibana/http_ca.crt
    mode: '0644'

- name: configure kibana
  template:
    src: kibana.yml.j2
    dest: /etc/kibana/kibana.yml
  notify: restart kibana

- name: start kibana
  systemd:
    name: kibana
    state: started
    enabled: yes
EOF

cat > $ANSIBLE_DIR/roles/elk/handlers/main.yml <<'EOF'
- name: restart elasticsearch
  systemd:
    name: elasticsearch
    state: restarted

- name: restart kibana
  systemd:
    name: kibana
    state: restarted
EOF

cat > $ANSIBLE_DIR/roles/elk/templates/elasticsearch.yml.j2 <<'EOF'
network.host: 0.0.0.0
http.port: 9200
discovery.type: single-node
xpack.security.enabled: true
xpack.security.enrollment.enabled: true
xpack.security.http.ssl:
  enabled: true
  key: /etc/elasticsearch/certs/http.key
  certificate: /etc/elasticsearch/certs/http.crt
  certificate_authorities: /etc/elasticsearch/certs/ca.crt
EOF

cat > $ANSIBLE_DIR/roles/elk/templates/kibana.yml.j2 <<'EOF'
server.port: 5601
server.host: "0.0.0.0"
elasticsearch.hosts: ["https://localhost:9200"]
elasticsearch.username: "kibana_system"
elasticsearch.password: "{{ kibana_system_password }}"
elasticsearch.ssl.certificateAuthorities: ["/etc/kibana/http_ca.crt"]
EOF

# ============================================
# 12. GitHub Actions
cat > $GITHUB_DIR/deploy.yml <<'EOF'
name: Deploy

on:
  push:
    branches:
      - main

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Install SSH key
        uses: webfactory/ssh-agent@v0.5.4
        with:
          ssh-private-key: ${{ secrets.SSH_PRIVATE_KEY }}

      - name: Run Ansible playbook
        run: |
          cd ansible
          ansible-playbook -i inventory/production.yml playbooks/site.yml
EOF

# ============================================
# 13. Terraform
cat > $TERRAFORM_DIR/main.tf <<'EOF'
terraform {
  required_providers {
    proxmox = {
      source  = "telmate/proxmox"
      version = "~> 2.9"
    }
  }
}

variable "pm_password" {
  type        = string
  description = "Proxmox root password"
  sensitive   = true
}

provider "proxmox" {
  pm_api_url      = "https://192.168.1.100:8006/api2/json"
  pm_user         = "root@pam"
  pm_password     = var.pm_password
  pm_tls_insecure = true
}

# Шаблон для создания ВМ
resource "proxmox_vm_qemu" "vm" {
  for_each = {
    bunker  = { id = 10000, ip = "192.168.1.10/24", name = "bunker" }
    zabbix  = { id = 10001, ip = "192.168.1.83/24", name = "zabbix" }
    web01   = { id = 10002, ip = "192.168.1.88/24", name = "web01" }
    web02   = { id = 10003, ip = "192.168.1.89/24", name = "web02" }
    balancer= { id = 11111, ip = "192.168.1.90/24", name = "balancer" }
    elk     = { id = 22222, ip = "192.168.1.31/24", name = "elk" }
  }

  name        = each.value.name
  target_node = "pve100"
  clone       = "ubuntu-22.04-template"  # должен существовать в proxmox

  # Для Zabbix используем Debian, можно задать условие
  # Для упрощения используем один шаблон, но в реальности надо клонировать разные.
  # Можно добавить переменную os_template и задавать для zabbix отдельно.

  cores   = 2
  memory  = 2048
  sockets = 1

  disk {
    type    = "virtio"
    storage = "local-lvm"
    size    = "20G"
  }

  network {
    model  = "virtio"
    bridge = "vmbr0"
  }

  os_type = "cloud-init"

  ipconfig0 = "ip=${each.value.ip},gw=192.168.1.1"

  sshkeys = file("~/.ssh/id_rsa.pub")  # ваш публичный ключ
}
EOF

cat > $TERRAFORM_DIR/variables.tf <<'EOF'
variable "pm_password" {
  description = "Password for Proxmox API"
  type        = string
  sensitive   = true
}
EOF

cat > $TERRAFORM_DIR/outputs.tf <<'EOF'
output "vm_ips" {
  value = {
    for k, vm in proxmox_vm_qemu.vm : k => vm.default_ipv4_address
  }
}
EOF

# ============================================
# 14. README.md для репозитория
cat > README.md <<'EOF'
# Проект инфраструктуры victoryur.tech

Данный репозиторий содержит код для развёртывания отказоустойчивой инфраструктуры веб-сайта victoryur.tech.

## Состав

- **Ansible** – автоматизация настройки серверов
- **Terraform** – создание виртуальных машин в Proxmox
- **GitHub Actions** – CI/CD для автоматического деплоя

## Структура

- `ansible/` – плейбуки, роли, инвентарь
- `terraform/` – конфигурация для создания ВМ
- `.github/workflows/` – CI/CD пайплайн

## Предварительные требования

- Установленный Ansible, Terraform
- Доступ по SSH к серверам (ключи)
- Настроенный Proxmox с шаблонами ОС
- Переменные окружения или vault для паролей
