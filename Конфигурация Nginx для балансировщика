upstream victoryur_backend {
    least_conn;

    server 192.168.1.88:80 max_fails=2 fail_timeout=5s;
    server 192.168.1.89:80 max_fails=2 fail_timeout=5s;

    keepalive 32;
}

# Доступ по IP: принудительно выставляем Host=victoryur.tech
server {
    listen 80;
    server_name 192.168.1.90;

    access_log /var/log/nginx/lb.ip.access.log;
    error_log  /var/log/nginx/lb.ip.error.log warn;

    add_header X-LB "balancer-192.168.1.90" always;
    add_header X-Upstream "$upstream_addr" always;
    add_header X-Upstream-Status "$upstream_status" always;

    location = /health {
        access_log off;
        return 200 "OK\n";
    }

    location / {
        proxy_http_version 1.1;
        proxy_set_header Connection "";

        # Фиксируем Host, иначе backend не матчится по server_name
        proxy_set_header Host              victoryur.tech;

        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 3s;
        proxy_send_timeout    30s;
        proxy_read_timeout    30s;

        proxy_next_upstream error timeout http_502 http_503 http_504;
        proxy_next_upstream_tries 2;

        proxy_pass http://victoryur_backend;
    }
}

# Основной vhost по домену: сохраняем Host как пришёл
server {
    listen 80 default_server;
    server_name victoryur.tech www.victoryur.tech;

    access_log /var/log/nginx/lb.victoryur.tech.access.log;
    error_log  /var/log/nginx/lb.victoryur.tech.error.log warn;

    add_header X-LB "balancer-192.168.1.90" always;
    add_header X-Upstream "$upstream_addr" always;
    add_header X-Upstream-Status "$upstream_status" always;

    location = /health {
        access_log off;
        return 200 "OK\n";
    }

    location / {
        proxy_http_version 1.1;
        proxy_set_header Connection "";

        # По домену сохраняем реальный Host
        proxy_set_header Host              $host;

        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 3s;
        proxy_send_timeout    30s;
        proxy_read_timeout    30s;

        proxy_next_upstream error timeout http_502 http_503 http_504;
        proxy_next_upstream_tries 2;

        proxy_pass http://victoryur_backend;
    }
}

